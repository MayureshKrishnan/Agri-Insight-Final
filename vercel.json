{
  "version": 2,
  "builds": [
    {
      "src": "web-assistant/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "ai-engine/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "ai-engine/api/index.py" },
    { "source": "/(.*)", "destination": "web-assistant/$1" }
  ]
}